page { background: #f1f4f8; }

.profile-hero {
  width: 100%;
  height: 190rpx;
  background: linear-gradient(135deg, #1769e0, #0d4fae);
}

.profile-page {
  margin-top: -112rpx;
  padding-top: 0;
}

.profile-box,
.menu-group {
  width: 100%;
  padding: 0 24rpx;
}

.profile-box {
  overflow: hidden;
  border-top-left-radius: 42rpx;
  border-top-right-radius: 42rpx;
}

.profile-head {
  display: flex;
  min-height: 250rpx;
  min-width: 0;
  align-items: center;
  justify-content: center;
  padding: 30rpx 4rpx 28rpx;
  border-bottom: 1rpx solid #e7edf5;
  flex-direction: column;
}

.avatar-button {
  display: flex;
  width: 140rpx !important;
  height: 140rpx;
  flex: 0 0 140rpx;
  align-items: center;
  justify-content: center;
  margin: 0 !important;
  overflow: hidden;
  border: 6rpx solid #ffffff;
  border-radius: 50%;
  background: #eaf2ff;
  box-shadow: 0 10rpx 24rpx rgba(13,79,174,.18);
}

.avatar-image { width: 100%; height: 100%; border-radius: 50%; }
.login-tip { max-width: 100%; margin-top: 16rpx; color: #7c8799; font-size: 24rpx; line-height: 1.5; text-align: center; }
.caregiver-info { width: 100%; min-width: 0; margin-top: 14rpx; }
.caregiver-name { color: #182230; font-size: 32rpx; font-weight: 700; text-align: center; }
.caregiver-meta { display: flex; min-width: 0; justify-content: space-between; gap: 18rpx; margin-top: 12rpx; color: #7c8799; font-size: 21rpx; }
.caregiver-meta text { width: 0; min-width: 0; flex: 1 1 0; }
.caregiver-meta text:last-child { text-align: right; }

.menu-group { margin-top: 20rpx; }
.menu-row { display: flex; width: 100% !important; min-width: 0; min-height: 104rpx; align-items: center; justify-content: space-between; gap: 16rpx; margin: 0 !important; padding: 20rpx 4rpx; border-bottom: 1rpx solid #e7edf5; text-align: left; }
.menu-row--last { border-bottom: 0; }
.menu-row__left { display: flex; width: 0; min-width: 0; flex: 1 1 0; align-items: center; gap: 18rpx; }
.menu-icon { width: 42rpx; height: 42rpx; flex: 0 0 42rpx; }
.menu-row__content { width: 0; min-width: 0; flex: 1 1 0; }
.menu-row__title { color: #344054; font-size: 27rpx; font-weight: 600; }
.menu-row__desc { margin-top: 5rpx; color: #8a96a8; font-size: 20rpx; }
.menu-chevron { width: 14rpx; height: 14rpx; flex: 0 0 14rpx; border-top: 3rpx solid #a4afbd; border-right: 3rpx solid #a4afbd; transform: rotate(45deg); }
.profile-notice { padding: 28rpx 16rpx; color: #9aa5b4; font-size: 20rpx; line-height: 1.5; text-align: center; }

@media (max-width: 360px) {
  .profile-page { margin-top: -96rpx; }
  .caregiver-meta { align-items: center; flex-direction: column; gap: 6rpx; }
  .caregiver-meta text { width: 100%; text-align: center !important; }
  .menu-row__desc { white-space: normal; }
}
