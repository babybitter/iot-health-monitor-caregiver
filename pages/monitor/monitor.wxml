<app-nav title="智能监控" subtitle="单患者实时查看"></app-nav>

<view class="page-shell page-shell--tab monitor-page">
  <state-panel wx:if="{{loading}}" type="loading" title="正在获取监控数据" description="正在同步生命体征和设备状态"></state-panel>
  <state-panel wx:elif="{{error}}" type="error" title="监控数据加载失败" description="{{error}}" action-text="重新加载" bind:action="retryLoad"></state-panel>
  <state-panel wx:elif="{{!patients.length}}" type="empty" title="暂无负责患者" description="分配服务对象后可在此查看监控数据"></state-panel>

  <block wx:else>
    <view class="patient-selector card">
      <picker mode="selector" range="{{patientNames}}" value="{{selectedIndex}}" bindchange="onPatientChange">
        <view class="patient-selector__main">
          <view class="patient-selector__identity">
            <view class="patient-selector__label">当前服务对象</view>
            <view class="patient-selector__name text-ellipsis">{{selectedPatient.displayName}}</view>
            <view class="patient-selector__meta text-ellipsis">{{selectedPatient.room}} · {{selectedPatient.bed}} · {{selectedPatient.careLevel}}</view>
          </view>
          <view class="patient-selector__side">
            <status-tag type="{{selectedPatient.status}}" text="{{selectedPatient.statusLabel}}"></status-tag>
            <view class="selector-chevron"></view>
          </view>
        </view>
      </picker>
      <view class="patient-selector__footer">
        <text class="text-ellipsis">更新于 {{lastUpdateLabel}}</text>
        <button class="refresh-button" disabled="{{refreshing}}" bindtap="refreshSnapshot">{{refreshing ? '刷新中' : '刷新'}}</button>
      </view>
    </view>

    <view wx:if="{{alerts.length}}" class="monitor-alert monitor-alert--{{alerts[0].level}}">
      <view class="monitor-alert__content">
        <view class="monitor-alert__title text-ellipsis">{{alerts[0].title}}</view>
        <view class="monitor-alert__desc line-clamp-2">{{alerts[0].description}}</view>
      </view>
      <button class="monitor-alert__action" data-id="{{alerts[0].id}}" disabled="{{submitting}}" bindtap="handleAlert">确认处理</button>
    </view>

    <view class="monitor-tabs">
      <button wx:for="{{tabs}}" wx:key="key" class="monitor-tab {{activeTab === item.key ? 'monitor-tab--active' : ''}}" data-key="{{item.key}}" bindtap="switchTab">{{item.label}}</button>
    </view>

    <view wx:if="{{activeTab === 'vitals'}}" class="tab-panel">
      <view class="vital-grid">
        <view wx:for="{{vitalCards}}" wx:key="type" class="vital-card vital-card--{{item.status}}">
          <view class="vital-card__top">
            <text class="vital-card__label">{{item.label}}</text>
            <text class="vital-card__status">{{item.statusLabel}}</text>
          </view>
          <view class="vital-card__reading">
            <text class="vital-card__value">{{item.value}}</text>
            <text class="vital-card__unit">{{item.unit}}</text>
          </view>
        </view>
      </view>

      <view class="section-heading">
        <view class="section-title">处理提醒</view>
      </view>
      <view class="care-note card">
        <view class="care-note__text line-clamp-2">健康数据仅用于辅助值守。出现异常时请先核对设备佩戴和现场情况，再按机构流程上报。</view>
        <button class="secondary-button care-note__button" bindtap="recordObservation">填写观察记录</button>
      </view>
    </view>

    <view wx:elif="{{activeTab === 'infusion'}}" class="tab-panel">
      <view class="infusion-card card">
        <view class="infusion-card__header">
          <view>
            <view class="infusion-card__title">输液余量监测</view>
            <view class="infusion-card__updated">更新于 {{infusionUpdateLabel || '--'}}</view>
          </view>
          <status-tag type="{{infusionStatus}}" text="{{infusionStatusText}}"></status-tag>
        </view>

        <view class="infusion-progress">
          <view class="infusion-progress__track">
            <view class="infusion-progress__fill infusion-progress__fill--{{infusionStatus}}" style="width: {{infusionPercent}}%;"></view>
          </view>
          <view class="infusion-progress__labels">
            <text>剩余 {{infusionPercent}}%</text>
            <text>{{infusion.remainingWeight || 0}} / {{infusion.initialWeight || 0}}g</text>
          </view>
        </view>

        <view class="infusion-stats">
          <view class="infusion-stat">
            <text class="infusion-stat__label">当前滴速</text>
            <text class="infusion-stat__value">{{infusion.speed || '--'}}<text class="infusion-stat__unit"> 滴/分</text></text>
          </view>
          <view class="infusion-stat">
            <text class="infusion-stat__label">告警阈值</text>
            <text class="infusion-stat__value">{{infusion.threshold || '--'}}<text class="infusion-stat__unit"> g</text></text>
          </view>
        </view>

        <view class="infusion-actions">
          <button class="secondary-button" bindtap="recordObservation">记录巡视</button>
          <button class="danger-button" disabled="{{submitting}}" bindtap="triggerInfusionAlert">触发设备提醒</button>
        </view>
      </view>
      <view wx:if="{{!infusion.initialWeight}}" class="inline-empty">当前服务对象没有进行中的输液监测</view>
    </view>

    <view wx:elif="{{activeTab === 'trend'}}" class="tab-panel">
      <scroll-view scroll-x="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}" class="metric-scroll">
        <view class="metric-options">
          <button wx:for="{{metricOptions}}" wx:key="key" class="metric-option {{selectedMetric === item.key ? 'metric-option--active' : ''}}" data-key="{{item.key}}" bindtap="selectMetric">{{item.label}}</button>
        </view>
      </scroll-view>

      <view class="trend-card card">
        <view class="trend-card__header">
          <view>
            <view class="trend-card__title">{{selectedMetricLabel}}趋势</view>
            <view class="trend-card__desc">仅显示当前服务对象</view>
          </view>
          <view class="range-switch">
            <button wx:for="{{ranges}}" wx:key="key" class="range-option {{selectedRange === item.key ? 'range-option--active' : ''}}" data-key="{{item.key}}" bindtap="selectRange">{{item.label}}</button>
          </view>
        </view>

        <state-panel wx:if="{{historyLoading}}" type="loading" compact="{{true}}" title="正在加载趋势"></state-panel>
        <state-panel wx:elif="{{historyError}}" type="error" compact="{{true}}" title="趋势加载失败" description="{{historyError}}" action-text="重试" bind:action="retryHistory"></state-panel>
        <state-panel wx:elif="{{!hasHistory}}" type="empty" compact="{{true}}" title="暂无趋势数据" description="切换时间范围后可再次查看"></state-panel>
        <block wx:else>
          <view class="history-summary">
            <view><text>最新</text><text>{{historySummary.latest}}</text></view>
            <view><text>最低</text><text>{{historySummary.min}}</text></view>
            <view><text>最高</text><text>{{historySummary.max}}</text></view>
          </view>
          <view class="chart-wrap">
            <ec-canvas id="trend-chart" canvas-id="trend-chart-canvas" ec="{{chartConfig}}"></ec-canvas>
          </view>
        </block>
      </view>
    </view>

    <view wx:else class="tab-panel">
      <view class="device-overview card">
        <view class="device-overview__top">
          <view>
            <view class="device-overview__title">设备连接</view>
            <view class="device-overview__desc">{{realtimeEnabled ? (realtimeConnected ? '实时通道已连接' : '实时通道未连接') : '当前使用模拟数据适配器'}}</view>
          </view>
          <status-tag type="{{realtimeConnected ? 'success' : realtimeEnabled ? 'warning' : 'neutral'}}" text="{{realtimeConnected ? '已连接' : realtimeEnabled ? '未连接' : '模拟模式'}}"></status-tag>
        </view>
      </view>
      <view wx:if="{{devices.length}}" class="device-list card">
        <view wx:for="{{devices}}" wx:key="id" class="device-row">
          <view class="device-row__mark">设</view>
          <view class="device-row__content">
            <view class="device-row__name text-ellipsis">{{item.name}}</view>
            <view class="device-row__updated text-ellipsis">{{item.updateLabel}}</view>
          </view>
          <status-tag type="{{item.status === 'online' ? 'success' : item.status === 'standby' ? 'neutral' : 'offline'}}" text="{{item.statusText}}"></status-tag>
        </view>
      </view>
      <state-panel wx:else type="empty" compact="{{true}}" title="暂无设备信息" description="设备绑定后可查看连接状态"></state-panel>

      <view class="section-heading">
        <view class="section-title">环境设备控制</view>
        <view class="control-mode">{{mockMode ? '演示模式' : '实时模式'}}</view>
      </view>
      <view wx:if="{{controls.length}}" class="control-list card">
        <view wx:for="{{controls}}" wx:key="key" class="control-row">
          <view class="control-row__content">
            <view class="control-row__name text-ellipsis">{{item.name}}</view>
            <view class="control-row__desc text-ellipsis">{{mockMode ? '仅更新本地演示状态' : realtimeConnected ? '通过实时通道发送控制指令' : '实时通道未连接'}}</view>
          </view>
          <switch color="#1769e0" checked="{{item.enabled}}" disabled="{{sendingControlKey === item.key || (!mockMode && !realtimeConnected)}}" data-key="{{item.key}}" bindchange="onDeviceControlChange"></switch>
        </view>
      </view>
    </view>
  </block>
</view>
