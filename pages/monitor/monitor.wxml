<app-nav title="智能监控" subtitle="当前设备实时数据"></app-nav>

<view class="page-shell page-shell--tab monitor-page">
  <view class="monitor-source card">
    <view class="monitor-source__main">
      <view class="monitor-source__identity">
        <view class="monitor-source__label">当前照护对象</view>
        <view class="monitor-source__name text-ellipsis">{{subject.displayName}}</view>
        <view class="monitor-source__meta text-ellipsis">{{subject.location}} · 单套实体设备</view>
      </view>
      <status-tag type="{{subjectStatusType}}" text="{{subjectStatus}}"></status-tag>
    </view>
    <view class="monitor-source__footer">
      <view class="connection-state">
        <view class="connection-dot {{realtimeConnected ? 'connection-dot--online' : ''}}"></view>
        <text class="text-ellipsis">{{realtimeConnected ? 'MQTT 已连接' : (connectionError || '正在连接 MQTT')}}</text>
      </view>
      <button class="refresh-button" disabled="{{refreshing}}" bindtap="refreshRealtime">{{refreshing ? '连接中' : '刷新连接'}}</button>
    </view>
    <view class="monitor-source__updated text-ellipsis">最近数据：{{lastUpdateLabel}}</view>
  </view>

  <view wx:if="{{alerts.length}}" class="monitor-alert monitor-alert--{{alerts[0].level}}">
    <view class="monitor-alert__content">
      <view class="monitor-alert__title text-ellipsis">{{alerts[0].title}}</view>
      <view class="monitor-alert__desc line-clamp-2">{{alerts[0].description}}</view>
    </view>
    <button class="monitor-alert__action" data-id="{{alerts[0].id}}" disabled="{{submitting}}" bindtap="handleAlert">现场核对</button>
  </view>

  <view class="monitor-tabs">
    <button wx:for="{{tabs}}" wx:key="key" class="monitor-tab {{activeTab === item.key ? 'monitor-tab--active' : ''}}" data-key="{{item.key}}" bindtap="switchTab">{{item.label}}</button>
  </view>

  <view wx:if="{{activeTab === 'vitals'}}" class="tab-panel">
    <view class="vital-grid">
      <view wx:for="{{vitalCards}}" wx:key="type" class="vital-card vital-card--{{item.status}}">
        <view class="vital-card__top">
          <text class="vital-card__label">{{item.label}}</text>
          <text class="vital-card__status">{{item.statusLabel}}</text>
        </view>
        <view class="vital-card__reading">
          <text class="vital-card__value">{{item.value}}</text>
          <text class="vital-card__unit">{{item.unit}}</text>
        </view>
      </view>
    </view>
    <view class="section-heading"><view class="section-title">值守说明</view></view>
    <view class="care-note card">
      <view class="care-note__text">健康数据仅用于辅助值守。出现异常时请先核对设备佩戴和现场情况，再按机构流程上报。</view>
      <button class="secondary-button care-note__button" bindtap="recordObservation">填写观察记录</button>
    </view>
  </view>

  <view wx:elif="{{activeTab === 'infusion'}}" class="tab-panel">
    <view class="infusion-card card">
      <view class="infusion-card__header">
        <view class="heading-main">
          <view class="infusion-card__title">输液余量监测</view>
          <view class="infusion-card__updated text-ellipsis">更新于 {{infusionUpdateLabel}}</view>
        </view>
        <status-tag type="{{infusionStatus}}" text="{{infusionStatusText}}"></status-tag>
      </view>
      <view class="infusion-progress">
        <view class="infusion-progress__track"><view class="infusion-progress__fill infusion-progress__fill--{{infusionStatus}}" style="width: {{infusionPercent}}%;"></view></view>
        <view class="infusion-progress__labels"><text>剩余 {{infusionPercent}}%</text><text>{{infusion.remainingWeight === null ? '--' : infusion.remainingWeight}} / {{infusion.initialWeight === null ? '--' : infusion.initialWeight}}g</text></view>
      </view>
      <view class="infusion-stats">
        <view class="infusion-stat"><text class="infusion-stat__label">当前滴速</text><text class="infusion-stat__value">{{infusion.speed === null ? '--' : infusion.speed}}<text class="infusion-stat__unit"> 滴/分</text></text></view>
        <view class="infusion-stat"><text class="infusion-stat__label">告警阈值</text><text class="infusion-stat__value">{{infusion.threshold === null ? '--' : infusion.threshold}}<text class="infusion-stat__unit"> g</text></text></view>
      </view>
      <view class="infusion-actions">
        <button class="secondary-button" bindtap="recordObservation">记录巡视</button>
        <button class="danger-button" disabled="{{submitting}}" bindtap="triggerInfusionAlert">触发设备提醒</button>
      </view>
    </view>
    <view wx:if="{{infusion.initialWeight === null}}" class="inline-empty">尚未收到 patient/monitor/weight-begin 的真实数据</view>
  </view>

  <view wx:elif="{{activeTab === 'trend'}}" class="tab-panel">
    <scroll-view scroll-x="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}" class="metric-scroll">
      <view class="metric-options">
        <button wx:for="{{metricOptions}}" wx:key="key" class="metric-option {{selectedMetric === item.key ? 'metric-option--active' : ''}}" data-key="{{item.key}}" bindtap="selectMetric">{{item.label}}</button>
      </view>
    </scroll-view>
    <view class="trend-card card">
      <view class="trend-card__header">
        <view class="heading-main"><view class="trend-card__title">{{selectedMetricLabel}}趋势</view><view class="trend-card__desc">仅使用本次运行实际收到的数据</view></view>
        <view class="range-switch"><button wx:for="{{ranges}}" wx:key="key" class="range-option {{selectedRange === item.key ? 'range-option--active' : ''}}" data-key="{{item.key}}" bindtap="selectRange">{{item.label}}</button></view>
      </view>
      <state-panel wx:if="{{!hasHistory}}" type="empty" compact="{{true}}" title="暂无真实趋势数据" description="收到所选指标的 MQTT 消息后会自动绘制"></state-panel>
      <block wx:else>
        <view class="history-summary"><view><text>最新</text><text>{{historySummary.latest}}</text></view><view><text>最低</text><text>{{historySummary.min}}</text></view><view><text>最高</text><text>{{historySummary.max}}</text></view></view>
        <view class="chart-wrap"><ec-canvas id="trend-chart" canvas-id="trend-chart-canvas" ec="{{chartConfig}}"></ec-canvas></view>
      </block>
    </view>
  </view>

  <view wx:else class="tab-panel">
    <view class="device-overview card">
      <view class="device-overview__top">
        <view class="heading-main"><view class="device-overview__title">设备连接</view><view class="device-overview__desc">订阅患者端相同的 MQTT 主题</view></view>
        <status-tag type="{{realtimeConnected ? 'success' : 'offline'}}" text="{{realtimeConnected ? '已连接' : '未连接'}}"></status-tag>
      </view>
    </view>
    <view class="device-list card">
      <view wx:for="{{devices}}" wx:key="id" class="device-row">
        <view class="device-row__mark">设</view>
        <view class="device-row__content"><view class="device-row__name text-ellipsis">{{item.name}}</view><view class="device-row__updated text-ellipsis">{{item.updateLabel}}</view></view>
        <status-tag type="{{item.status === 'online' ? 'success' : item.status === 'standby' || item.status === 'unknown' ? 'neutral' : 'offline'}}" text="{{item.statusText}}"></status-tag>
      </view>
    </view>
    <view class="section-heading"><view class="section-title">环境设备控制</view><view class="control-mode">实时模式</view></view>
    <view class="control-list card">
      <view wx:for="{{controls}}" wx:key="key" class="control-row">
        <view class="control-row__content"><view class="control-row__name text-ellipsis">{{item.name}}</view><view class="control-row__desc text-ellipsis">{{item.feedbackReceived ? '已收到设备状态反馈' : realtimeConnected ? '等待设备状态反馈' : 'MQTT 通道未连接'}}</view></view>
        <switch color="#1769e0" checked="{{item.enabled}}" disabled="{{sendingControlKey === item.key || !realtimeConnected}}" data-key="{{item.key}}" bindchange="onDeviceControlChange"></switch>
      </view>
    </view>
  </view>
</view>
