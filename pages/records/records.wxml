<app-nav title="照护记录" subtitle="工作事项与处理结果" back="{{true}}"></app-nav>

<view class="page-shell records-page">
  <view class="records-toolbar">
    <picker class="records-picker" mode="selector" range="{{patientNames}}" value="{{selectedIndex}}" bindchange="onPatientChange">
      <view class="records-picker__value text-ellipsis">{{patientNames[selectedIndex]}}</view>
    </picker>
    <button class="primary-button records-add" bindtap="addRecord">新增记录</button>
  </view>
  <view class="records-total">共 {{total}} 条记录</view>

  <state-panel wx:if="{{loading}}" type="loading" title="正在加载照护记录"></state-panel>
  <state-panel wx:elif="{{error}}" type="error" title="照护记录加载失败" description="{{error}}" action-text="重新加载" bind:action="retryLoad"></state-panel>
  <state-panel wx:elif="{{!records.length}}" type="empty" title="暂无照护记录" description="完成照护事项后可新增简短记录" action-text="新增记录" bind:action="addRecord"></state-panel>

  <view wx:else class="record-list">
    <view wx:for="{{records}}" wx:key="id" class="record-card card">
      <view class="record-card__top">
        <view class="record-card__identity">
          <view class="record-card__name text-ellipsis">{{item.patient.displayName}} · {{item.patient.bed}}</view>
          <view class="record-card__time">{{item.timeLabel}}</view>
        </view>
        <status-tag type="primary" text="{{item.type}}" dot="{{false}}"></status-tag>
      </view>
      <view class="record-card__content">{{item.content}}</view>
      <view class="record-card__result"><text>处理结果</text><text>{{item.result}}</text></view>
      <view class="record-card__author">记录人：{{item.author}}</view>
    </view>

    <button wx:if="{{hasMore}}" class="load-more" disabled="{{loadingMore}}" bindtap="loadMore">{{loadingMore ? '加载中' : '查看更多'}}</button>
    <view wx:else class="list-end">已显示全部匹配记录</view>
  </view>
</view>

