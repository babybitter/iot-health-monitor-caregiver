.network-banner {
  position: relative;
  z-index: 10;
  width: 100%;
  padding: 14rpx 24rpx;
  background: #fff4df;
  color: #80500b;
  font-size: 22rpx;
  line-height: 1.45;
  text-align: center;
  word-break: break-word;
}

.duty-card {
  padding: 30rpx;
  border-color: #cfe0f5;
  background: linear-gradient(145deg, #ffffff 0%, #f0f6ff 100%);
}

.duty-card__top {
  display: flex;
  min-width: 0;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.duty-card__identity {
  min-width: 0;
  flex: 1;
}

.duty-card__greeting {
  overflow-wrap: anywhere;
  color: #182230;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.35;
}

.duty-card__shift {
  margin-top: 10rpx;
  color: #5e6b7d;
  font-size: 24rpx;
  line-height: 1.55;
}

.duty-card__actions {
  display: flex;
  min-width: 0;
  align-items: stretch;
  gap: 16rpx;
  margin-top: 28rpx;
}

.attendance-button {
  display: flex;
  min-width: 0;
  min-height: 88rpx;
  flex: 1;
  align-items: flex-start;
  justify-content: center;
  padding: 18rpx 24rpx;
  border-radius: 16rpx;
  background: #1769e0;
  color: #ffffff;
  flex-direction: column;
  font-size: 28rpx;
  font-weight: 650;
  text-align: left;
}

.attendance-button[disabled] {
  background: #a5b5c9;
}

.attendance-button__meta {
  max-width: 100%;
  margin-top: 4rpx;
  overflow: hidden;
  color: rgba(255, 255, 255, 0.8);
  font-size: 20rpx;
  font-weight: 400;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.attendance-history {
  display: flex;
  width: 160rpx;
  flex: 0 0 160rpx;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  border: 1rpx solid #a9c8f5;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.82);
  color: #0d4fae;
  font-size: 24rpx;
  font-weight: 600;
}

.summary-grid {
  display: grid;
  width: 100%;
  min-width: 0;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 20rpx;
}

.summary-card {
  display: flex;
  min-width: 0;
  min-height: 134rpx;
  align-items: flex-start;
  justify-content: center;
  padding: 22rpx 18rpx;
  border: 1rpx solid #dfe6ef;
  border-radius: 20rpx;
  background: #ffffff;
  flex-direction: column;
  box-shadow: 0 6rpx 20rpx rgba(31, 58, 91, 0.04);
  text-align: left;
}

.summary-card--danger {
  border-color: #f2cbd0;
  background: #fff8f8;
}

.summary-card__value {
  color: #182230;
  font-size: 42rpx;
  font-weight: 720;
  line-height: 1.1;
}

.summary-card--danger .summary-card__value {
  color: #c43a47;
}

.summary-card__label {
  max-width: 100%;
  margin-top: 10rpx;
  color: #69778a;
  font-size: 22rpx;
  line-height: 1.35;
  word-break: break-word;
}

.alert-list,
.task-list {
  padding: 0 26rpx;
}

.alert-row {
  position: relative;
  display: flex;
  width: 100%;
  min-width: 0;
  align-items: center;
  gap: 18rpx;
  padding: 26rpx 0;
  border-bottom: 1rpx solid #edf1f5;
  text-align: left;
}

.alert-row:last-child,
.task-row:last-child {
  border-bottom: 0;
}

.alert-row__rail {
  width: 8rpx;
  height: 76rpx;
  flex: 0 0 8rpx;
  border-radius: 999rpx;
  background: #a96309;
}

.alert-row__rail--danger {
  background: #c43a47;
}

.alert-row__content {
  min-width: 0;
  flex: 1;
}

.alert-row__headline {
  display: flex;
  min-width: 0;
  align-items: center;
  gap: 12rpx;
}

.alert-row__title {
  min-width: 0;
  flex: 1;
  color: #273444;
  font-size: 28rpx;
  font-weight: 650;
}

.alert-row__meta,
.task-row__meta {
  margin-top: 8rpx;
  color: #7c8799;
  font-size: 22rpx;
  line-height: 1.4;
}

.alert-row__description {
  margin-top: 8rpx;
  color: #5e6b7d;
  font-size: 23rpx;
  line-height: 1.5;
}

.row-chevron {
  width: 16rpx;
  height: 16rpx;
  flex: 0 0 16rpx;
  border-top: 3rpx solid #9aa6b6;
  border-right: 3rpx solid #9aa6b6;
  transform: rotate(45deg);
}

.patient-strip {
  width: calc(100% + 24rpx);
  margin-right: -24rpx;
  overflow: hidden;
}

.patient-strip__inner {
  display: inline-flex;
  min-width: 100%;
  gap: 16rpx;
  padding-right: 24rpx;
}

.patient-card {
  display: flex;
  width: 76vw;
  min-width: 460rpx;
  max-width: 520rpx;
  min-height: 230rpx;
  padding: 26rpx;
  border: 1rpx solid #dfe6ef;
  border-radius: 22rpx;
  background: #ffffff;
  flex-direction: column;
  box-shadow: 0 6rpx 20rpx rgba(31, 58, 91, 0.05);
  text-align: left;
}

.patient-card__top {
  display: flex;
  min-width: 0;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.patient-card__name {
  min-width: 0;
  flex: 1;
  color: #182230;
  font-size: 30rpx;
  font-weight: 650;
}

.patient-card__bed {
  margin-top: 12rpx;
  color: #5e6b7d;
  font-size: 23rpx;
}

.patient-card__note {
  min-height: 66rpx;
  margin-top: 16rpx;
  color: #344054;
  font-size: 23rpx;
  line-height: 1.48;
}

.patient-card__update {
  margin-top: auto;
  padding-top: 14rpx;
  color: #8a96a8;
  font-size: 20rpx;
}

.latest-monitor {
  display: flex;
  width: 100%;
  min-width: 0;
  align-items: center;
  gap: 18rpx;
  margin-top: 16rpx;
  padding: 22rpx 24rpx;
  text-align: left;
}

.latest-monitor__identity {
  min-width: 0;
  flex: 1;
}

.latest-monitor__label {
  overflow: hidden;
  color: #273444;
  font-size: 24rpx;
  font-weight: 600;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.latest-monitor__status {
  margin-top: 6rpx;
  color: #16845b;
  font-size: 20rpx;
}

.latest-monitor__metric {
  min-width: 86rpx;
  flex: 0 1 100rpx;
  text-align: right;
}

.latest-monitor__metric text {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.latest-monitor__metric text:first-child {
  color: #182230;
  font-size: 28rpx;
  font-weight: 680;
}

.latest-monitor__metric text:last-child {
  margin-top: 4rpx;
  color: #8a96a8;
  font-size: 19rpx;
}

.task-row {
  display: flex;
  width: 100%;
  min-width: 0;
  align-items: center;
  gap: 18rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #edf1f5;
  text-align: left;
}

.task-row__time {
  width: 82rpx;
  flex: 0 0 82rpx;
  color: #0d4fae;
  font-size: 25rpx;
  font-weight: 650;
}

.task-row__body {
  min-width: 0;
  flex: 1;
}

.task-row__title {
  color: #273444;
  font-size: 27rpx;
  font-weight: 600;
}

@media (max-width: 360px) {
  .duty-card__actions { flex-wrap: wrap; }
  .attendance-history { width: 100%; flex-basis: 100%; min-height: 72rpx; }
  .summary-grid { gap: 10rpx; }
  .summary-card { padding: 20rpx 12rpx; }
  .summary-card__label { font-size: 20rpx; }
}
