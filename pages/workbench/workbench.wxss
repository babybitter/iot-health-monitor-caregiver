.network-banner {
  position: relative;
  z-index: 10;
  width: 100%;
  padding: 14rpx 24rpx;
  background: #fff4df;
  color: #80500b;
  font-size: 22rpx;
  line-height: 1.45;
  text-align: center;
}

.duty-card {
  padding: 30rpx;
  border-color: #cfe0f5;
  background: linear-gradient(145deg, #ffffff 0%, #f0f6ff 100%);
}

.duty-card__top,
.duty-card__actions,
.subject-card__main,
.alert-row,
.alert-row__headline,
.latest-monitor,
.task-row {
  display: flex;
  min-width: 0;
}

.duty-card__top { align-items: flex-start; justify-content: space-between; gap: 20rpx; }
.duty-card__identity { min-width: 0; flex: 1; }
.duty-card__greeting { overflow-wrap: anywhere; color: #182230; font-size: 36rpx; font-weight: 700; line-height: 1.35; }
.duty-card__shift { margin-top: 10rpx; color: #5e6b7d; font-size: 24rpx; line-height: 1.55; }
.duty-card__actions { align-items: stretch; gap: 16rpx; margin-top: 28rpx; }

.attendance-button {
  display: flex;
  width: 0;
  min-height: 88rpx;
  min-width: 0;
  flex: 1 1 0;
  align-items: flex-start;
  justify-content: center;
  padding: 18rpx 24rpx;
  border-radius: 16rpx;
  background: #1769e0;
  color: #ffffff;
  flex-direction: column;
  font-size: 28rpx;
  font-weight: 650;
  text-align: left;
}
.attendance-button[disabled] { background: #a5b5c9; }
.attendance-button__meta { max-width: 100%; margin-top: 4rpx; overflow: hidden; color: rgba(255,255,255,.8); font-size: 20rpx; font-weight: 400; text-overflow: ellipsis; white-space: nowrap; }
.attendance-history { display: flex; width: 160rpx; flex: 0 0 160rpx; align-items: center; justify-content: center; padding: 16rpx; border: 1rpx solid #a9c8f5; border-radius: 16rpx; background: rgba(255,255,255,.82); color: #0d4fae; font-size: 24rpx; font-weight: 600; }

.summary-grid { display: flex; width: 100%; min-width: 0; gap: 14rpx; margin-top: 20rpx; }
.summary-card { display: flex; width: 0 !important; min-width: 0; min-height: 134rpx; flex: 1 1 0; align-items: flex-start; justify-content: center; padding: 22rpx 16rpx; border: 1rpx solid #dfe6ef; border-radius: 20rpx; background: #ffffff; flex-direction: column; box-shadow: 0 6rpx 20rpx rgba(31,58,91,.04); text-align: left; }
.summary-card--danger { border-color: #f2cbd0; background: #fff8f8; }
.summary-card__value { max-width: 100%; overflow: hidden; color: #182230; font-size: 42rpx; font-weight: 720; line-height: 1.1; text-overflow: ellipsis; white-space: nowrap; }
.summary-card__value--text { font-size: 30rpx; }
.summary-card--danger .summary-card__value { color: #c43a47; }
.summary-card__label { max-width: 100%; margin-top: 10rpx; color: #69778a; font-size: 21rpx; line-height: 1.35; word-break: break-word; }

.section-caption { flex: 0 0 auto; color: #8a96a8; font-size: 22rpx; }
.alert-list,.task-list { width: 100%; padding: 0 24rpx; }
.alert-row,.task-row { width: 100% !important; margin: 0 !important; align-items: center; gap: 16rpx; padding: 24rpx 0; border-bottom: 1rpx solid #edf1f5; text-align: left; }
.alert-row:last-child,.task-row:last-child { border-bottom: 0; }
.alert-row__rail { width: 8rpx; height: 76rpx; flex: 0 0 8rpx; border-radius: 999rpx; background: #a96309; }
.alert-row__rail--danger { background: #c43a47; }
.alert-row__content { width: 0; min-width: 0; flex: 1 1 0; }
.alert-row__headline { align-items: center; gap: 10rpx; }
.alert-row__title { width: 0; min-width: 0; flex: 1 1 0; color: #273444; font-size: 27rpx; font-weight: 650; }
.alert-row__meta,.task-row__meta { margin-top: 7rpx; color: #7c8799; font-size: 21rpx; line-height: 1.4; }
.alert-row__description { margin-top: 7rpx; color: #5e6b7d; font-size: 22rpx; line-height: 1.5; }
.row-chevron { width: 14rpx; height: 14rpx; flex: 0 0 14rpx; border-top: 3rpx solid #9aa6b6; border-right: 3rpx solid #9aa6b6; transform: rotate(45deg); }

.subject-card { display: block; width: 100% !important; margin: 0 !important; padding: 26rpx; text-align: left; }
.subject-card__main { align-items: center; gap: 16rpx; }
.subject-card__mark { display: flex; width: 68rpx; height: 68rpx; flex: 0 0 68rpx; align-items: center; justify-content: center; border-radius: 18rpx; background: #eaf2ff; color: #0d4fae; font-size: 24rpx; font-weight: 700; }
.subject-card__identity { width: 0; min-width: 0; flex: 1 1 0; }
.subject-card__name { color: #182230; font-size: 29rpx; font-weight: 650; }
.subject-card__meta { margin-top: 6rpx; color: #7c8799; font-size: 21rpx; }
.subject-card__updated { margin-top: 18rpx; padding-top: 16rpx; border-top: 1rpx solid #edf1f5; color: #8a96a8; font-size: 21rpx; }

.latest-monitor { width: 100% !important; margin: 16rpx 0 0 !important; align-items: center; gap: 14rpx; padding: 22rpx; text-align: left; }
.latest-monitor__identity { width: 0; min-width: 110rpx; flex: 1 1 0; }
.latest-monitor__label { overflow: hidden; color: #273444; font-size: 24rpx; font-weight: 600; text-overflow: ellipsis; white-space: nowrap; }
.latest-monitor__status { margin-top: 6rpx; overflow: hidden; color: #69778a; font-size: 19rpx; text-overflow: ellipsis; white-space: nowrap; }
.latest-monitor__metric { width: 92rpx; min-width: 0; flex: 0 1 92rpx; text-align: right; }
.latest-monitor__metric text { display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.latest-monitor__metric text:first-child { color: #182230; font-size: 24rpx; font-weight: 680; }
.latest-monitor__metric text:last-child { margin-top: 4rpx; color: #8a96a8; font-size: 18rpx; }

.task-row__time { width: 78rpx; flex: 0 0 78rpx; color: #0d4fae; font-size: 24rpx; font-weight: 650; }
.task-row__body { width: 0; min-width: 0; flex: 1 1 0; }
.task-row__title { color: #273444; font-size: 26rpx; font-weight: 600; }

@media (max-width: 360px) {
  .duty-card__actions { flex-wrap: wrap; }
  .attendance-history { width: 100%; flex-basis: 100%; min-height: 72rpx; }
  .summary-grid { gap: 10rpx; }
  .summary-card { padding: 18rpx 10rpx; }
  .summary-card__label { font-size: 19rpx; }
  .latest-monitor__metric:nth-of-type(4) { display: none; }
}
