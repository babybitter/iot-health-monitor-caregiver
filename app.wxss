@import "/styles/theme.wxss";

page {
  min-height: 100%;
  background: var(--color-background);
  color: var(--color-text);
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  overflow-x: hidden;
}

view,
scroll-view,
button,
input,
textarea,
picker,
image {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  line-height: inherit;
  border-radius: 0;
  background: transparent;
  color: inherit;
  font-size: inherit;
}

button::after {
  border: 0;
}

.page-shell {
  width: 100%;
  min-height: 100vh;
  padding: 24rpx 24rpx calc(40rpx + env(safe-area-inset-bottom));
  overflow-x: hidden;
}

.page-shell--tab {
  padding-bottom: calc(36rpx + env(safe-area-inset-bottom));
}

.card {
  width: 100%;
  min-width: 0;
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-card);
  background: var(--color-surface);
  box-shadow: var(--shadow-card);
  overflow: hidden;
}

.section-heading {
  display: flex;
  min-width: 0;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin: 36rpx 2rpx 20rpx;
}

.section-title {
  min-width: 0;
  color: var(--color-text);
  font-size: 32rpx;
  font-weight: 650;
  line-height: 1.4;
}

.section-action {
  flex: 0 0 auto;
  color: var(--color-primary);
  font-size: 24rpx;
  line-height: 1.4;
}

.primary-button,
.secondary-button,
.danger-button {
  display: flex;
  min-height: 80rpx;
  min-width: 0;
  align-items: center;
  justify-content: center;
  padding: 18rpx 28rpx;
  border-radius: var(--radius-button);
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.35;
  text-align: center;
  word-break: break-word;
}

.primary-button {
  background: var(--color-primary);
  color: #ffffff;
}

.primary-button[disabled] {
  background: #9bbce9;
  color: rgba(255, 255, 255, 0.88);
}

.secondary-button {
  border: 1rpx solid var(--color-primary-border);
  background: var(--color-primary-soft);
  color: var(--color-primary-dark);
}

.danger-button {
  border: 1rpx solid #f4b9bf;
  background: var(--color-danger-soft);
  color: var(--color-danger);
}

.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.line-clamp-2 {
  display: -webkit-box;
  overflow: hidden;
  word-break: break-word;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.safe-bottom {
  height: env(safe-area-inset-bottom);
}

