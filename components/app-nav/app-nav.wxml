<view class="nav-placeholder" style="height: {{totalHeight}}px;"></view>
<view class="app-nav {{transparent ? 'app-nav--transparent' : ''}}" style="height: {{totalHeight}}px; padding-top: {{statusBarHeight}}px;">
  <view class="app-nav__content" style="height: {{contentHeight}}px; padding-left: {{back ? '16px' : '24rpx'}}; padding-right: {{rightInset}}px;">
    <view
      wx:if="{{back}}"
      class="app-nav__back"
      role="button"
      aria-label="返回"
      hover-class="app-nav__back--pressed"
      hover-stay-time="80"
      catchtap="goBack"
    >
      <image class="app-nav__back-icon" src="/images/back.png" mode="aspectFit"></image>
    </view>
    <view class="app-nav__heading">
      <view class="app-nav__title text-ellipsis">{{title}}</view>
      <view wx:if="{{subtitle}}" class="app-nav__subtitle text-ellipsis">{{subtitle}}</view>
    </view>
  </view>
</view>
