.nav-placeholder {
  width: 100%;
}

.app-nav {
  position: fixed;
  z-index: 900;
  top: 0;
  right: 0;
  left: 0;
  border-bottom: 1rpx solid rgba(223, 230, 239, 0.88);
  background: rgba(255, 255, 255, 0.96);
}

.app-nav--transparent {
  border-bottom-color: transparent;
  background: rgba(255, 255, 255, 0.92);
}

.app-nav__content {
  display: flex;
  min-width: 0;
  align-items: center;
  gap: 16rpx;
}

.app-nav__back {
  display: flex;
  width: 64rpx;
  height: 64rpx;
  flex: 0 0 64rpx;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
}

.app-nav__back:active {
  background: #edf3fb;
}

.app-nav__chevron {
  width: 20rpx;
  height: 20rpx;
  border-bottom: 4rpx solid #182230;
  border-left: 4rpx solid #182230;
  transform: rotate(45deg);
}

.app-nav__heading {
  min-width: 0;
  flex: 1;
}

.app-nav__title {
  color: #182230;
  font-size: 32rpx;
  font-weight: 650;
  line-height: 1.3;
}

.app-nav__subtitle {
  margin-top: 2rpx;
  color: #7c8799;
  font-size: 20rpx;
  line-height: 1.25;
}

